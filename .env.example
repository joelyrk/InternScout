COMPOSE_PROJECT_NAME=internscout

POSTGRES_DB=internscout
POSTGRES_TEST_DB=internscout_test
POSTGRES_USER=internscout
POSTGRES_PASSWORD=local-development-only
POSTGRES_PORT=5432

REDIS_PORT=6379

INTERNSCOUT_ENVIRONMENT=development
INTERNSCOUT_LOG_LEVEL=INFO
INTERNSCOUT_DATABASE_URL=postgresql+psycopg://internscout:local-development-only@localhost:5432/internscout
INTERNSCOUT_TEST_DATABASE_URL=postgresql+psycopg://internscout:local-development-only@localhost:5432/internscout_test
INTERNSCOUT_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
